<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Para Nicole 💛</title>

<style>

body {
    margin: 0;
    overflow: hidden;
    font-family: "Georgia", serif;
    background: linear-gradient(#87ceeb, white);
    text-align: center;
}

/* Texto principal */

.mensaje {
    position: absolute;
    top: 8%;
    width: 100%;
    font-size: 40px;
    font-style: italic;
    color: #8B0000;
}

.submensaje {

    position: absolute;
    top: 16%;
    width: 100%;
    font-size: 22px;
    color: #444;
}

/* Flores */

.flor {

    position: absolute;
    width: 80px;
    animation: crecer 3s ease-in-out infinite alternate;
}

@keyframes crecer {

    from { transform: scale(0.9);}
    to { transform: scale(1.1);}
}

/* corazones flotando */

.corazon {

    position: absolute;
    color: #ff4d6d;
    font-size: 22px;
    animation: flotar 6s linear infinite;
}

@keyframes flotar {

    0% {
        transform: translateY(0);
        opacity: 1;
    }

    100% {

        transform: translateY(-800px);
        opacity: 0;
    }
}

.boton {

    position: absolute;
    bottom: 80px;
    left: 50%;
    transform: translateX(-50%);

    background: gold;
    border: none;
    padding: 15px 35px;

    font-size: 20px;

    border-radius: 30px;

    cursor: pointer;

}

.boton:hover {

    background: orange;
}

</style>
</head>


<body>


<div class="mensaje">

Para Nicole, mi sol amarillo 💛

</div>


<div class="submensaje">

Hoy quiero regalarte flores amarillas,  
porque desde que llegaste a mi vida  
todo tiene más luz 🌼

</div>


<button class="boton" onclick="mostrarMensaje()">

Haz clic aquí Nicole 🌻

</button>



<script>

/* generar flores */

for(let i=0;i<7;i++){

let flor=document.createElement("div")

flor.innerHTML="🌼"

flor.className="flor"

flor.style.left=Math.random()*90+"%"

flor.style.top=(60+Math.random()*30)+"%"

flor.style.fontSize=(40+Math.random()*30)+"px"

document.body.appendChild(flor)

}


/* generar corazones */

setInterval(()=>{

let corazon=document.createElement("div")

corazon.innerHTML="💛"

corazon.className="corazon"

corazon.style.left=Math.random()*100+"%"

corazon.style.bottom="0px"

document.body.appendChild(corazon)

setTimeout(()=>corazon.remove(),6000)

},600)



/* mensaje final romántico */

function mostrarMensaje(){

alert(

`Nicole 💛

Estas flores amarillas son solo un pequeño símbolo
de lo mucho que significas para mí.

Gracias por tu sonrisa,
por tu ternura,
y por hacer mis días más bonitos.

Me haces feliz 🌼`
)

}

</script>


</body>
</html>